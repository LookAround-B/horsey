# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/horsey?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────────
JWT_SECRET=horsey-jwt-secret-change-me-in-production
JWT_REFRESH_SECRET=horsey-refresh-secret-change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
NEXTAUTH_SECRET=horsey-nextauth-secret-change-me
NEXTAUTH_URL=http://localhost:3000

# ─── Twilio (OTP) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_VERIFY_SERVICE_SID=...

# ─── Razorpay ────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=...
RAZORPAY_KEY_SECRET=...

# ─── Pusher (Real-time) ─────────────────────────────────────────────────
PUSHER_APP_ID=...
PUSHER_KEY=...
PUSHER_SECRET=...
PUSHER_CLUSTER=ap2

# ─── Cloudinary (Media) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ─── Resend (Email) ─────────────────────────────────────────────────────
RESEND_API_KEY=...

# ─── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
