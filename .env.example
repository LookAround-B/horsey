# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/horsey?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=<min 64 char random hex — used for signing access tokens>
JWT_REFRESH_SECRET=<min 64 char random hex — DIFFERENT from access — used for refresh tokens>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption (for MFA secrets at rest) ────────────────────────────────
ENCRYPTION_KEY=<32-byte hex string (64 hex chars) — used for AES-256-GCM>

# ─── Security ─────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
SESSION_SECRET=<min 64 char random hex>

# ─── Google OAuth ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
NEXTAUTH_SECRET=horsey-nextauth-secret-change-me
NEXTAUTH_URL=http://localhost:3000

# ─── Apple OAuth ─────────────────────────────────────────────────────────
APPLE_CLIENT_ID=...
APPLE_TEAM_ID=...
APPLE_KEY_ID=...
APPLE_PRIVATE_KEY=...

# ─── Twilio (OTP) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_VERIFY_SERVICE_SID=...

# ─── Razorpay ────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=...
RAZORPAY_KEY_SECRET=...

# ─── Pusher (Real-time) ─────────────────────────────────────────────────
PUSHER_APP_ID=...
PUSHER_KEY=...
PUSHER_SECRET=...
PUSHER_CLUSTER=ap2

# ─── Cloudinary (Media) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ─── Resend (Email) ─────────────────────────────────────────────────────
RESEND_API_KEY=...

# ─── Frontend ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://horseyb.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
