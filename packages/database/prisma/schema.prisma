generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  VENDOR
  BUYER
}

enum AuthEvent {
  REGISTER_EMAIL
  REGISTER_GOOGLE
  REGISTER_APPLE
  REGISTER_PHONE
  LOGIN_EMAIL
  LOGIN_GOOGLE
  LOGIN_APPLE
  LOGIN_PHONE
  LOGIN_FAILED
  LOGIN_BLOCKED
  LOGOUT
  LOGOUT_ALL
  TOKEN_REFRESH
  TOKEN_REFRESH_REUSE_DETECTED
  EMAIL_VERIFY_SENT
  EMAIL_VERIFIED
  PHONE_OTP_SENT
  PHONE_VERIFIED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PASSWORD_CHANGED
  MFA_ENABLED
  MFA_DISABLED
  MFA_VERIFY_FAILED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  SESSION_REVOKED
  ALL_SESSIONS_REVOKED
  SUSPICIOUS_ACTIVITY
}

enum RidingDiscipline {
  ENGLISH
  WESTERN
  BOTH
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  TERMINATED
}

enum ListingStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  ARCHIVED
  SOLD
}

enum SubOrderStatus {
  PENDING_ACCEPTANCE
  ACCEPTED
  DECLINED
  AUTO_CANCELLED
  SHIPPED
  DELIVERED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model User {
  id                    String            @id @default(cuid())
  email                 String?           @unique
  phone                 String?           @unique
  name                  String
  role                  UserRole          @default(BUYER)
  avatarUrl             String?
  bio                   String?
  ridingDiscipline      RidingDiscipline?
  emailVerified         Boolean           @default(false)
  emailVerifyToken      String?           @unique
  emailVerifyTokenExpiry DateTime?
  paymentMethodToken    String?

  // Auth
  passwordHash          String?
  googleId              String?           @unique
  appleId               String?           @unique
  fcmToken              String?
  phoneVerified         Boolean           @default(false)
  isActive              Boolean           @default(true)
  isBanned              Boolean           @default(false)
  banReason             String?
  mfaEnabled            Boolean           @default(false)
  mfaSecret             String?
  mfaBackupCodes        String?           // JSON array of hashed backup codes
  failedLoginAttempts   Int               @default(0)
  lockedUntil           DateTime?
  lastLoginAt           DateTime?
  lastLoginIp           String?
  lastLoginUserAgent    String?
  passwordChangedAt     DateTime?
  passwordResetToken    String?           @unique
  passwordResetExpiry   DateTime?

  // Relations
  addresses             Address[]
  vendor                Vendor?
  orders                Order[]
  cart                  Cart?
  notifications         Notification[]
  reviews               Review[]
  disputes              Dispute[]
  auditLogs             AuditLog[]
  sessions              Session[]
  refreshTokens         RefreshToken[]
  authAuditLogs         AuthAuditLog[]

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([email])
  @@index([phone])
  @@index([role])
}

model Session {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken      String   @unique
  deviceFingerprint String?
  userAgent         String?
  ipAddress         String?
  isRevoked         Boolean  @default(false)
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  lastUsedAt        DateTime @default(now())

  @@index([userId])
}

model RefreshToken {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash      String   @unique
  familyId       String
  isRevoked      Boolean  @default(false)
  replacedByHash String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  userAgent      String?
  ipAddress      String?

  @@index([userId])
  @@index([tokenHash])
  @@index([familyId])
}

model AuthAuditLog {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  event         AuthEvent
  ipAddress     String
  userAgent     String?
  metadata      Json?
  success       Boolean
  failureReason String?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([event, userId])
}

model Address {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String?
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean    @default(false)
  isStable  Boolean    @default(false)
  subOrders SubOrder[]
  createdAt DateTime   @default(now())

  @@index([userId])
}

// ─── Vendor & KYC ─────────────────────────────────────────────────────────────

model Vendor {
  id             String         @id @default(cuid())
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName   String
  gstNumber      String?
  panNumber      String?
  bankAccountRef String?
  status         VendorStatus   @default(PENDING)
  kycDocuments   KycDocument[]
  products       Product[]
  subOrders      SubOrder[]
  strikes        VendorStrike[]
  payouts        Payout[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
}

model KycDocument {
  id         String   @id @default(cuid())
  vendorId   String
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  type       String
  url        String
  uploadedAt DateTime @default(now())
}

// ─── Catalog ───────────────────────────────────────────────────────────────────

model Category {
  id         String      @id @default(cuid())
  name       String
  slug       String      @unique
  parentId   String?
  parent     Category?   @relation("SubCategories", fields: [parentId], references: [id])
  children   Category[]  @relation("SubCategories")
  attributes Json
  slaHours   Int         @default(24)
  products   Product[]
  createdAt  DateTime    @default(now())
}

model Product {
  id              String          @id @default(cuid())
  vendorId        String
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  categoryId      String
  category        Category        @relation(fields: [categoryId], references: [id])
  title           String
  description     String
  price           Decimal         @db.Decimal(12, 2)
  status          ListingStatus   @default(DRAFT)
  inventory       Int             @default(0)
  lowStockAlert   Int             @default(5)
  freightRequired Boolean         @default(false)
  isFeatured      Boolean         @default(false)
  attributes      Json
  media           ProductMedia[]
  variants        ProductVariant[]
  orderItems      OrderItem[]
  reviews         Review[]
  scheduledAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([vendorId])
  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
}

model ProductVariant {
  id         String    @id @default(cuid())
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  label      String
  sku        String    @unique
  price      Decimal?  @db.Decimal(12, 2)
  inventory  Int       @default(0)
  orderItems OrderItem[]
}

model ProductMedia {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  type      String
  order     Int     @default(0)
}

// ─── Cart ──────────────────────────────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  variantId String?
  quantity  Int     @default(1)

  @@index([cartId])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id             String     @id @default(cuid())
  buyerId        String
  buyer          User       @relation(fields: [buyerId], references: [id])
  subOrders      SubOrder[]
  paymentAuthId  String?
  totalAmount    Decimal    @db.Decimal(12, 2)
  createdAt      DateTime   @default(now())

  @@index([buyerId])
}

model SubOrder {
  id                 String         @id @default(cuid())
  orderId            String
  order              Order          @relation(fields: [orderId], references: [id])
  vendorId           String
  vendor             Vendor         @relation(fields: [vendorId], references: [id])
  status             SubOrderStatus @default(PENDING_ACCEPTANCE)
  items              OrderItem[]
  addressId          String
  address            Address        @relation(fields: [addressId], references: [id])
  shippingMethod     String?
  notes              String?
  trackingNumber     String?
  acceptanceDeadline DateTime
  acceptedAt         DateTime?
  declinedAt         DateTime?
  declineReason      String?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  paymentCaptureId   String?
  isHorsePurchase    Boolean        @default(false)
  buyerAttestation   Boolean        @default(false)
  vetCheckRequested  Boolean        @default(false)
  escrowRequested    Boolean        @default(false)
  strikes            VendorStrike[]
  payout             Payout?
  dispute            Dispute?
  notifications      Notification[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([orderId])
  @@index([vendorId])
  @@index([status])
}

model OrderItem {
  id         String          @id @default(cuid())
  subOrderId String
  subOrder   SubOrder        @relation(fields: [subOrderId], references: [id])
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  quantity   Int
  unitPrice  Decimal         @db.Decimal(12, 2)

  @@index([subOrderId])
}

// ─── SLA ──────────────────────────────────────────────────────────────────────

model VendorStrike {
  id         String   @id @default(cuid())
  vendorId   String
  vendor     Vendor   @relation(fields: [vendorId], references: [id])
  subOrderId String
  subOrder   SubOrder @relation(fields: [subOrderId], references: [id])
  reason     String   @default("AUTO_CANCEL_SLA_BREACH")
  createdAt  DateTime @default(now())

  @@index([vendorId])
}

model PlatformDowntime {
  id        String    @id @default(cuid())
  startedAt DateTime
  endedAt   DateTime?
  reason    String
  createdAt DateTime  @default(now())
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id         String          @id @default(cuid())
  subOrderId String
  buyerId    String
  buyer      User            @relation(fields: [buyerId], references: [id])
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  vendorId   String
  rating     Int
  body       String?
  photos     ReviewPhoto[]
  response   ReviewResponse?
  isFlagged  Boolean         @default(false)
  createdAt  DateTime        @default(now())

  @@index([productId])
  @@index([vendorId])
}

model ReviewPhoto {
  id       String @id @default(cuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url      String
}

model ReviewResponse {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  vendorId  String
  body      String
  createdAt DateTime @default(now())
}

// ─── Payouts ──────────────────────────────────────────────────────────────────

model Payout {
  id          String       @id @default(cuid())
  vendorId    String
  vendor      Vendor       @relation(fields: [vendorId], references: [id])
  subOrderId  String       @unique
  subOrder    SubOrder     @relation(fields: [subOrderId], references: [id])
  amount      Decimal      @db.Decimal(12, 2)
  status      PayoutStatus @default(PENDING)
  razorpayId  String?
  scheduledAt DateTime
  paidAt      DateTime?
  createdAt   DateTime     @default(now())

  @@index([vendorId])
  @@index([status])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  body       String
  subOrderId String?
  subOrder   SubOrder? @relation(fields: [subOrderId], references: [id])
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([userId, isRead])
}

// ─── Admin ────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
}

model Dispute {
  id         String          @id @default(cuid())
  subOrderId String          @unique
  subOrder   SubOrder        @relation(fields: [subOrderId], references: [id])
  openedById String
  openedBy   User            @relation(fields: [openedById], references: [id])
  status     DisputeStatus   @default(OPEN)
  messages   DisputeMessage[]
  resolvedAt DateTime?
  createdAt  DateTime        @default(now())

  @@index([status])
}

model DisputeMessage {
  id         String   @id @default(cuid())
  disputeId  String
  dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderId   String
  senderRole String
  body       String
  createdAt  DateTime @default(now())
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
